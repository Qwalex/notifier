# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_chat_id_here

# VK: токен сообщества с доступом к сообщениям + peer_id получателя (обычно ID пользователя)
# https://dev.vk.com/ru/method/messages.send
VK_ACCESS_TOKEN=your_vk_group_access_token_here
VK_PEER_ID=your_vk_peer_id_here

# Server Configuration
PORT=5656
NODE_ENV=production
