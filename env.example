# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_chat_id_here

# VK: только ключ доступа СООБЩЕСТВА (Управление → Настройки → Работа с API → ключ с правом «Сообщения»).
# Не подходит пользовательский access_token от приложения.
# VK_PEER_ID — числовой id пользователя ВК (не @ник). Пользователь должен написать сообществу
# или открыть ЛС от сообщества, иначе API вернёт 901 и т.п.
# https://dev.vk.com/ru/method/messages.send
VK_ACCESS_TOKEN=your_vk_group_access_token_here
VK_PEER_ID=your_vk_peer_id_here

# Server Configuration
PORT=5656
NODE_ENV=production
